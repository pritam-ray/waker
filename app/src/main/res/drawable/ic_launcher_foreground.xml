<?xml version="1.0" encoding="utf-8"?>
<!--
    Launcher icon foreground — 108×108 dp canvas, safe zone is the inner 72×72 dp.
    Radar / pulse target symbol: three concentric rings + solid centre dot.
    All drawn in green (#4CAF50) to stand out against the dark background.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Outer ring -->
    <path
        android:fillColor="#00000000"
        android:strokeColor="#4CAF50"
        android:strokeWidth="5"
        android:pathData="M54,54 m-30,0 a30,30 0 1,0 60,0 a30,30 0 1,0 -60,0" />

    <!-- Middle ring -->
    <path
        android:fillColor="#00000000"
        android:strokeColor="#4CAF50"
        android:strokeWidth="5"
        android:pathData="M54,54 m-19,0 a19,19 0 1,0 38,0 a19,19 0 1,0 -38,0" />

    <!-- Centre dot -->
    <path
        android:fillColor="#4CAF50"
        android:pathData="M54,54 m-7,0 a7,7 0 1,0 14,0 a7,7 0 1,0 -14,0" />

</vector>
