<?xml version="1.0" encoding="utf-8"?>
<!--
    Allow cleartext (HTTP) traffic to any domain.
    Waker lets users supply arbitrary URLs, which may use http:// — blocking cleartext
    would silently break those pings on Android 9+ (targetSdk 28+).
    All network calls are user-initiated and user-defined, so this is appropriate.
-->
<network-security-config>
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
